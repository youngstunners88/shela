# English Learning Tetris - Environment Variables

# AI Coach API (optional)
# Provides personalized pre-game briefings based on your learning history
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Voice Integration (optional)
# Enables pronunciation practice with AI voice
# Get your key at: https://elevenlabs.io/api
ELEVENLABS_API_KEY=...

# Database (optional - uses localStorage by default)
# Uncomment to use Supabase for cross-device sync
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
