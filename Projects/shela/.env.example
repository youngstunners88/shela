# Shela Environment Variables
# Copy to .env and fill in your values

# ============== DATABASE ==============
DATABASE_URL=postgres://shela:password@localhost:5432/shela
DB_PASSWORD=your_secure_password_here

# ============== SOLANA ==============
SOLANA_RPC=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=your_base58_private_key
TREASURY_PROGRAM_ID=your_program_id_after_deployment
REPUTATION_PROGRAM_ID=your_program_id_after_deployment
SLASH_ORACLE_PROGRAM_ID=your_program_id_after_deployment

# ============== NOTIFICATIONS ==============
NTIFY_TOPIC=https://ntfy.sh/shela-your-topic

# ============== AI MODELS ==============
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
VERCEL_KIMI_API_KEY=your_vercel_key

# ============== WEBSOCKET ==============
WS_PORT=3001
REDIS_URL=redis://localhost:6379

# ============== API ==============
PORT=3000
NODE_ENV=development
JWT_SECRET=your_random_jwt_secret

# ============== ZK PROOFS ==============
ZK_PROVER_URL=http://localhost:8080
CIRCUIT_PATH=./zk/circuit.circom

# ============== SENTRY (Error Tracking) ==============
SENTRY_DSN=your_sentry_dsn

# ============== RATE LIMITING ==============
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
